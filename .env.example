# Kopiere nach .env.local für lokale Entwicklung.
# Auf Vercel: Project → Settings → Environment Variables (Production + Preview)
# Nach dem Setzen: Redeploy auslösen (NEXT_PUBLIC_* werden beim Build eingebettet).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Nur für Server/API (nicht NEXT_PUBLIC_):
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # Screen Top-10 + Admin-Sync

# TheSportsDB Premium (Screen + Edge Function sync-matches):
# SPORTSDB_API_KEY=your_premium_api_key
# SPORTSDB_LEAGUE_ID=4429
# SPORTSDB_SEASON=2026
